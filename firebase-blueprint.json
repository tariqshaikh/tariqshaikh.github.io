{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in." }
      },
      "required": ["uid", "email"]
    },
    "Scenario": {
      "title": "Financial Scenario",
      "description": "A saved financial simulation with specific parameters.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the scenario." },
        "userId": { "type": "string", "description": "The UID of the owner." },
        "name": { "type": "string", "description": "Name of the scenario (e.g., 'Current Path', 'Early Retirement')." },
        "monthlySavings": { "type": "number", "description": "Monthly savings amount." },
        "annualReturn": { "type": "number", "description": "Expected annual return percentage." },
        "initialWealth": { "type": "number", "description": "Starting wealth amount." },
        "years": { "type": "number", "description": "Simulation time horizon in years." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the scenario was last modified." }
      },
      "required": ["userId", "name", "monthlySavings", "annualReturn", "initialWealth", "years"]
    },
    "NetWorthItem": {
      "title": "Net Worth Item",
      "description": "A single line item in the net worth calculator (asset or liability).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "category": { "type": "string", "enum": ["Joint Accounts", "Retirement 1", "Retirement 2", "Investments", "Debt", "Other"] },
        "name": { "type": "string" },
        "value": { "type": "number" },
        "isAsset": { "type": "boolean" },
        "institution": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "name", "value", "isAsset"]
    },
    "NetWorthSnapshot": {
      "title": "Net Worth Snapshot",
      "description": "A historical record of total net worth at a point in time.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "totalAssets": { "type": "number" },
        "totalLiabilities": { "type": "number" },
        "netWorth": { "type": "number" }
      },
      "required": ["userId", "date", "netWorth"]
    },
    "VisitorLog": {
      "title": "Visitor Log",
      "description": "A record of a page visit.",
      "type": "object",
      "properties": {
        "path": { "type": "string", "description": "The URL path visited." },
        "referrer": { "type": "string", "description": "The referring URL." },
        "userAgent": { "type": "string", "description": "The visitor's browser user agent." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the visit occurred." },
        "userId": { "type": "string", "description": "The UID of the user if logged in." },
        "sessionId": { "type": "string", "description": "A temporary session ID." },
        "screenResolution": { "type": "string", "description": "The visitor's screen resolution." }
      },
      "required": ["path", "timestamp"]
    },
    "OrbitProfile": {
      "title": "Orbit Profile",
      "description": "User's income and fixed expenses for Orbit.",
      "type": "object",
      "properties": {
        "primaryIncome": { "type": "object" },
        "spouseIncome": { "type": "object" },
        "fixedExpenses": { "type": "array" },
        "savingsGoal": { "type": "number" },
        "cardColors": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "OrbitExpense": {
      "title": "Orbit Expense",
      "description": "A recurring expense in the Orbit app.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "number" },
        "frequency": { "type": "string" },
        "category": { "type": "string" },
        "customCategory": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/visitorLogs/{logId}": {
      "schema": "VisitorLog",
      "description": "Publicly writable logs of page visits."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/scenarios/{scenarioId}": {
      "schema": "Scenario",
      "description": "A user's saved financial scenarios."
    },
    "/users/{userId}/netWorthItems/{itemId}": {
      "schema": "NetWorthItem",
      "description": "Individual assets and liabilities."
    },
    "/users/{userId}/netWorthHistory/{snapshotId}": {
      "schema": "NetWorthSnapshot",
      "description": "Historical net worth snapshots."
    },
    "/users/{userId}/orbitProfile/main": {
      "schema": "OrbitProfile",
      "description": "User's Orbit profile settings."
    },
    "/users/{userId}/orbitExpenses/{expenseId}": {
      "schema": "OrbitExpense",
      "description": "User's recurring Orbit expenses."
    }
  }
}
